        opt     nol        lib     sysconfig.h        if      ((NET=1)|(NETBLCK=1))        lib     ../include/params.h        lib     ../include/macdefs.h        lib     ../include/wzsock.h        lib     ../include/fio.h        lib     ../include/fio_ctrl.h        lib     ../include/fio_codes.h        lib     ../include/nwp_codes.h        lib     ../include/ust.h        opt     lis        data** basic net device* its purpose is to set the local side* of the w5500 device* [260511] added special device to read GPP memory*        global  wzopn,wzcls,wzrdd,wzwrd,wzspc* regular socket interface deviceMAXNET  set     0        if      (NET=1)MAXNET  set     1        endif* netblock device and NO socket device        if      (NETBLCK=1)MAXNET  set     1        endifMX_NETD equ     MAXNETwzcurd  rzb     1wzopfl  rzb     3wzopn   equ     *        pshs    x,y,u        ldx     #wzopfl        cmpb    #MX_NETD        bhs     03f        abx        tst     0,x        bne     01f        inc     0,x        stb     wzcurd          set currents device02      puls    x,y,u,pc03      cmpb    #255            special device        beq     02b             ok*        lda     #EBARG        bra     04f01      lda     #EBSY04      sta     uerror        bra     02bwzcls   equ     *        ldx     #wzopfl        cmpb    #MX_NETD        bhs     03f        abx        clr     0,x        rts03      cmpb    #255            special        beq     04        lda     #EBARG        sta     uerror04      rts** read configuration data, B=minor*wzrdd   equ     *        pshs    x,y,u        ldy     #NWP0           get parameter base address* X=fifo        cmpb    #255            special device        lbeq    cpu_read*        ldu     fio_dba,y        ldx     fifo_us1,u      offset to GW data        addr    U,X             U + X -> X        lda     uicnt+1        cmpa    #WZLCSZ        DCFLEN        lbhi     81f            allow for less*        pshs    x,u        tfr     x,u            U points to fifo_us1        lda     #2             wzrdev        ldb     #S_SPCL        jsr     fio_msg        this read the device registers back        puls    x,u        tstb                   check error        bmi     20f        lda     uicnt+1         'DCFLEN'02      pshs    a        ldb     0,x+        pshs    x,y,u        jsr     passc        puls    x,y,u          uistrt / uicnt        puls    a        bmi     03f        deca        bne     02b*03      puls    x,y,u,pc20      stb     uerror        bra     03b** write configuration data, B=minor*wzwrd   equ     *        pshs    x,y,u        ldy     #NWP0           get parameter base address        ldu     fio_dba,y        ldx     fifo_us1,u        addr    U,X             U + X -> X*        cmpb    #255            special device?        beq     81f             not allowed*        lda     uicnt+1         check 'specific size'        cmpa    #WZLCSZ         DCFLEN        bhi     81f             allow for 'less'*        pshs    x               us1 address02      pshs    a,x,y,u        jsr     cpass        puls    a,x,y,u        bmi     03f        stb     0,x+        deca        bne     02b*03      ldb     #S_SPCL        lda     #0        puls    u               make U point to us1 area        jsr     fio_msg         tell IOP to put it in device*        puls    x,y,u,pcwzspc   equ     *        tfr     x,y        sty     -2,s            test Y        bne     doget* doset        ldy     #NWP0           get parameter base address        lda     usarg0+1        ldu     fio_dba,y        ldx     fifo_us1,u        leax    32,x        tfr     x,u             special area* U= device info        ldb     #S_SPCL        jsr     fio_msg         make IOP do it        rtsdoget   equ     *        pshs    x,y,u*81      lda     #EBARG82      sta     uerror        puls    x,y,u,pc** cpu_read, dump GPP memory page* x,y,u on stack* Y = NWP0* U = fio_dba*cpu_read ldx    fio_dba,y        ldd     uipos+2        lsra                    512 byte chunks        tfr     a,b        clra        std     fifo_us3,x      set page#        leax    fifo,x*        jsr     get_F_S         lock fifo for me        ldd     uicnt        cmpd    fio_fsz,y        bls     01f        ldd     fio_fsz,y       max size* D is count, X = dev buffer01      pshs    d,x        clra        ldb     #S_PG2FIFO        jsr     fio_msg        tstb        bmi     86f        puls    d,x*        jsr     db2um        bcs     85f*        ldd     uicnt           update data count        subd    fio_fsz,y        std     uicnt*98      jsr     FIFO_unlock99      puls    x,y,u,pc86      puls    d,x85      jsr     FIFO_unlock        bra     81b        else        data        nop        endif        end