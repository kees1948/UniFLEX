** command executors*        global  open_uio,close_uio,req_write,write_data        global  req_read,read_data,ttyset,ttyget,memp2ff** on entry, X = task struct, [cmd, sdata, pid, dev]* Y = function address, U = device reference*open_uio  equ   *          bsr   setdev          U = DPR ref, Y = tty struct          bmi   01f*          lda  #%10000000       <<          sta  dpflags,u          lda  tflags,y          ora  #%00000001       <<          sta  tflags,y          clra          ldb  #R_OPEN01        rts** sedev, check input parms, set device refeneces*setdev    ldy   #TTYTABS          tfr   u,d          cmpa  #UIOCHAR          bne   01f             error          cmpb  #MAX_DEV          bhs   01f          lda   #TTYSIZ          mul          leay  d,y          tfr   u,d          ldu   fifo_us1          lda   #DPDSIZ          mul          leau  d,u          clrb          rts01        ldb   #E_BADDEV          rtsclose_uio equ   *          bsr   setdev          bmi   01f          clr   dpflags,u        <<          clr   tflags,y        <<          ldb   #R_CLOSE          clra01        rtsreq_write equ   *write_data equ  *req_read  equ   *read_data equ   *ttyset    equ   *ttyget    equ   *          nop          rtssdev_sig  nop          rts