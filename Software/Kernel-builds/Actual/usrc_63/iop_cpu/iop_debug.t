*********************************************************************** memp2ff, mem pointer to fifo* copy 'fio_dsz'  bytes addressed by fifo_us3 to fifo***********************************************************************memp2ff equ     *        ldx     fifo_us3        get address        ldd     fio_fsz        pshs    d        std     fifo_cnt        set contents        trfr    D,W        ldy     #debbuf         make first a copy        tfm1    X,Y        ldx     #debbuf        pulsw        ldy     #fifo        tfm1    X,Y        clra        ldb     #R_RDOK        rts