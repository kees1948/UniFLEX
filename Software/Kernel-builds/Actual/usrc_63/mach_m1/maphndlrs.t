        lib     maphndlrs.h        sttl    Map and Mapping Handlers        pag        name    map_handlers opt exp        global  swtchu,xmapsp,mapbuf,mapxbf,mapsbf        global  mapupg,mapupg2,instbf,mapua2x        global  mapspg,mapbpt,mapbf2,mapxpt        global  ckpgcr,um2db,db2um** All routines in this file are machine dependent.* Most of them deal with the memory swapping* scheme.*** swtchu** Switch users top page* kernel stack is replaced!*swtchu  puls   y              get return address        stb    usrtop         set new top page        stb    DATBOX+USRLOC  set map reg        stb    sysmap+USRLOC  set new system map        lds    umark0         reset kernel sp's        jmp    0,y            do return** xmapsp** Map in new user-block which is in B.* Kernel stack is replaced*xmapsp  puls   x              get return address        stb    DATBOX+USRLOC  set new user loc        stb    sysmap+USRLOC  set in system map        stb    usrtop         set user top too ****** ?? ******* 4-11-80        jmp    0,x            return pag** mapbuf** Map a system buffer into SBUFFR space.  On* entry, x is pointing to a system buffer header.*mapbuf  ldd    bfxadr,x       get extended part of addrmapbf2  andb   #%11110000     mask top 4 bits        eorb   DATsense       make bits true        lsld        lsld        lsld        lsld*!* sld 4 shift left 4 timesmapsbf  sta    DATBOX+SBUF    set into SBUFFR        sta    sysmap+SBUF    CS 2024-04-30        rts                   return** mapbfx** Map a system buffer into XBUFFR space.  On* entry, x is pointing to a system buffer header.*mapbfx  ldd     bfxadr,x        get extended part of address        andb    #%11110000      mask top 4 bits        eorb    DATsense        lsld        lsld        lsld        lsld** mapxbf** Map a user segment into the XBUFFR space.*  Returns carry set if illegal page.*mapxbf  cmpa   BLKHOL         legal page?        bne    00f            yes - jump        pshs   d,x            no - blow the guy away        ldb    #FALTS        ldx    utask        jsr    xmtint         send SIGNAL to task        puls   d,x        lda    WHTHOL         use a good page        sec        bra    01f*00      clc                  no mapping errors01      sta    DATBOX+XBUF   set into XBUFFR        sta    sysmap+XBUF   save in system map copy        rts                  return** mapspg** Map the segment in B into system space at A offset.*mapspg  pshs   x             save x        ldx    #DATBOX       point to datbox        stb    a,x           set in segment        puls   x,pc          return** mapxpt** Map in buffer in X.  Return X pointing to buffer* in XBUFFER and D has offset.*mapxpt  bsr    mapbfx        map in buffer        ldd    bfadr,x       get address A15...A0        anda   #%00001111    mask out top bits        ldx    #XBUFFR       point to SBUFFR        leax   d,x           point to buffer        rts                  return** mapbpt** Map in buffer in X.  Return X pointing to buffer* in SBUFFER and D has offset.*mapbpt  bsr    mapbuf        map in buffer        ldd    bfadr,x       get address A15...A0        anda   #%00001111    mask out top bits        ldx    #SBUFFR       point to SBUFFR        leax   d,x           point to buffer        rts                  return** mapupg** Return the extended address bits in A:B which* represent the physical address of the virtual* address in D.*mapupg  ldx    #umem         point to memory map*mapupg2 tfr    a,b           save a        andb   #%00001111    mask low 4 bits leave A11...A8        pshs   b             save it        lsra                 get segment number index A15...A12        lsra                 memory page        lsra        lsra        ldb    a,x           get actual page number        pshs   b             save it        eorb   DATsense        lslb                 get back to bigh nibble        lslb                 leave A15...A12        lslb        lslb        orb    1,s           or in with low part        stb    1,s           save result        puls   d             A=page, B=A15...A8        lsra                 get 4 bits only        lsra        lsra        lsra                 A=A19...A16        rts                  return** mapua2x, map user address to XBUFFER address* on entry D contains user address*mapua2x pshs    d,x        lsra        lsra        lsra        lsra        ldx     #umem        ldb     a,x        eorb    DATsense        stb     sysmap+XBUF        stb     DATBOX+XBUF        ldx     #XBUFFR        ldd     0,s        anda    #$0f            find location in XBUFFER        leax    d,x        stx     0,s        puls    d,x,pc pag** instbf** Install the next available buffer into the* buffer header pointed to by Y.  Systmp points* to the current segment address and sbpag* has the current segment offset.*instbf  ldx    systmp        point to segment        lda    sbpag         get offset (index)        cmpa   #8            end of segment?        bne    instb2        clr    sbpag         reset to 0 offset (index)        leax   1,x           point to next segment        stx    systmp        save pointerinstb2  clr    bfadr+1,y     low word of address is always 0        ldb    0,x           get segment number        clra                 get into machine dependent form        lsld        lsld        lsld        lsld*!* sld 4        eorb   DATsense        andb   #%11110000        lsl    sbpag         index        orb    sbpag        lsr    sbpag         index        std    bfxadr,y      set in extended address        inc    sbpag         bump offset byte        rts                  return** ckpgcr, check page crossing in transfer* when using the HD63X09 tfm1 instruction to copy data fast,* check if the transfer is to be whtin the same 4K page or* spills over to another one in the user process memory** a max of PAGSIZ transfer is allowed* on entry D holds the transfer size* uistrt is the user memory start address for the transfer* on exit D,X each contain the sizes for the current page resp.* for the next page*ckpgcr  equ     *        cmpd    #PAGSIZ         max allowed        bhs     91f*        pshs    d               'var1'  [X]        clrd        pshs    d               allocate second var, 'var2' [D]        ldd     uistrt          user memory        addd    2,s             check upper boundary        bcs     90f             illegal        cmpa    #MXUMEM/256     inhibut upper memory        bhs     90f*        ldd     uistrt        anda    #$0f            within one page        addd    2,s             does it fit?        bita    #$f0            is zero, it does        beq     01f             every thing is ok* page cross        anda    #$0f            remainder 'var2'        std     0,s        ldd     uistrt          get seconds part        negd        anda    #$0f        std     2,s             first part 'var1'* no erros found01      clc                     no error        puls    d,x,pc          var2,var1 in D,X* some errors90      puls    d,x             empty stack91      sec                     set error        rts** um2db, user memory to device buffer* D holds data length, X holds device buffer address*um2db   pshs    d,x,u        lda     #1              direction flag        bra     10f** db2um, device bufer to user memory* D holds data langth, X holds device buffer address*db2um   pshs    d,x,u        clra                    direction flag* common code10      pshs    a               save flag        ldd     1,s             restore D        jsr     ckpgcr          check and get var1,var2        bcs     90f             error occurred*        pshs    d,x             save var2,var1        ldu     7,s             old X, device buffer address*        ldwx    2,IS            var1        ldd     uistrt          user address        jsr     mapua2x         to X buffer        tfr     d,x             user mem        tst     4,s             direction        beq     20f        exg     x,u             swap registers (!)20      tfm1    U,X             pseudo dma*        ldwx    0,IS            var2        beq     22f             done*        ldd     7,s             on writes, U is lost        addd    2,s        tfr     d,u             restore the correct U value*        ldd     uistrt        addd    2,s             new start in user address        jsr     mapua2x         into X buffer        tfr     d,x        tst     4,s             direction        beq     24f        exg     x,u             swap registers24      tfm1    U,X22      leas    4,s             clean var1,var2        clc30      leas    1,s             dirction flag        puls    d,x,u,pc* some error90      sec        bra     30b             exit